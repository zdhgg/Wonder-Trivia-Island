# Development ports
HOST=0.0.0.0
PORT=3008
API_PORT=8008

# Optional database override
# TRIVIA_DB_PATH=backend/data/trivia.db

# Optional: allow browser access from specific cross-origin frontends.
# Leave blank for the default same-origin deployment model.
# Multiple origins can be comma-separated.
# CORS_ORIGIN=http://localhost:3008,https://example.com

# Optional admin key for import / catalog mutation routes
# ADMIN_IMPORT_KEY=change-me

# Optional AI runtime defaults
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_QUESTION_MODEL=gpt-5.4-mini
# OPENAI_REVIEW_MODEL=gpt-5.4-mini
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=1
